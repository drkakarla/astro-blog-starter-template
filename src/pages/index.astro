/* ── FAQ ACCORDION ── */
.faq-section{margin-top:1.5rem}
.faq-item{border:1px solid var(--stone-200);border-radius:var(--r-lg);margin-bottom:.6rem;overflow:hidden;background:#fff;transition:border-color .15s}
.faq-item:hover{border-color:var(--blue-200)}
.faq-item[open]{border-color:var(--blue-600);background:var(--blue-50)}
