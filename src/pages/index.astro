/* ── TOKENS ── */
:root {
  --navy-950:#050e1a; --navy-900:#0f2040; --navy-800:#152b52; --navy-700:#1a3563;
  --blue-600:#1a68c2; --blue-500:#2479d8; --blue-200:#bfdbf7; --blue-100:#ddeeff; --blue-50:#f0f7ff;
