.consult-questions summary::-webkit-details-marker{display:none}
.consult-questions summary::after{content:'+';font-size:1.15rem;font-weight:300;color:var(--blue-600)}
.consult-questions[open] summary::after{content:'\2212'}
.consult-questions-list{padding:0 1.5rem 1.25rem;margin:0}
.consult-questions-list li{font-size:.88rem;color:var(--stone-600);margin-bottom:.4rem;line-height:1.5}

/* ── AUTHOR ATTRIBUTION ── */
.author-block{display:flex;align-items:center;gap:1rem;padding:1.5rem;background:var(--stone-50);border:1px solid var(--stone-200);border-radius:var(--r-xl);margin-top:3rem}
.author-avatar{width:56px;height:56px;border-radius:50%;object-fit:cover;flex-shrink:0;border:2px solid var(--blue-200)}
.author-info{font-size:.82rem;color:var(--stone-500);line-height:1.5}
.author-info strong{color:var(--stone-700);display:block;font-size:.88rem}
.author-info a{color:var(--blue-600)}
.author-info time{color:var(--stone-400)}

/* ── RELATED PILLS ── */
.related-strip{padding:1.25rem 1.5rem;background:var(--stone-50);border-top:1px solid var(--stone-200);border-bottom:1px solid var(--stone-200)}
.related-strip-inner{max-width:820px;margin:0 auto}
.related-strip-label{font-size:.62rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--stone-500);margin-bottom:.6rem}
.related-pills{display:flex;flex-wrap:wrap;gap:.45rem}
.related-pill{display:inline-flex;padding:.45rem .9rem;background:#fff;border:1px solid var(--stone-300);border-radius:100px;font-size:.78rem;font-weight:500;color:var(--stone-700);text-decoration:none;white-space:nowrap;transition:border-color .15s,background .15s}
.related-pill:hover{border-color:var(--blue-600);background:var(--blue-50);color:var(--blue-600)}

/* ── MID-PAGE CTA ── */
.mid-cta{margin:2rem 0;padding:1.5rem 2rem;background:linear-gradient(135deg,var(--navy-900),var(--navy-800));border-radius:var(--r-xl);display:flex;align-items:center;justify-content:space-between;gap:1.5rem;flex-wrap:wrap}
.mid-cta p{color:rgba(255,255,255,.85);font-size:.93rem;margin:0;font-weight:500}
.mid-cta p strong{color:#fff}
.mid-cta-actions{display:flex;gap:.75rem;flex-shrink:0}
.mid-cta .btn{font-size:.82rem;padding:.6rem 1.25rem;min-height:42px}
@media(max-width:550px){.mid-cta{flex-direction:column;text-align:center}.mid-cta-actions{width:100%;justify-content:center}}

/* ── PREP CHECKLIST ── */
.prep-grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin:1.5rem 0}
.prep-card{background:#fff;border:1px solid var(--stone-200);border-radius:var(--r-xl);padding:1.5rem}
.prep-card-title{font-size:.88rem;font-weight:600;color:var(--navy-900);margin:0 0 .75rem}
.prep-list{list-style:none;padding:0;margin:0}
.prep-list li{font-size:.85rem;color:var(--stone-600);padding:.35rem 0;border-bottom:1px solid var(--stone-100);line-height:1.5}
.prep-list li:last-child{border:none}
.prep-list li strong{color:var(--stone-900)}
@media(max-width:550px){.prep-grid{grid-template-columns:1fr}}

/* ── SURGERY DAY STEPS ── */
.surgery-day-steps{display:flex;flex-direction:column;gap:0;margin:1.5rem 0}
.sd-step{display:grid;grid-template-columns:80px 1fr;border-bottom:1px solid var(--stone-200);padding:1rem 0}
.sd-step:last-child{border:none}
.sd-time{font-family:var(--font-display);font-size:.9rem;color:var(--navy-900);padding-top:.1rem}
.sd-desc{font-size:.88rem;color:var(--stone-600);line-height:1.6}
.sd-desc strong{color:var(--stone-900)}

/* ── LOCATION CARDS ── */
.location-cards{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin:1.5rem 0}
.location-card-item{border:1px solid var(--stone-200);border-radius:var(--r-xl);padding:1.5rem 1.75rem;background:#fff;position:relative}
.location-card-item.primary{border-color:var(--blue-200);background:var(--blue-50)}
.location-card-item.primary::before{content:'';position:absolute;top:0;left:0;width:100%;height:4px;background:var(--blue-600);border-radius:var(--r-xl) var(--r-xl) 0 0}
.loc-label{font-size:.62rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--blue-600);margin-bottom:.375rem}
.loc-name{font-family:var(--font-display);font-size:1.05rem;color:var(--navy-900);margin:0 0 .375rem;font-weight:400}
.loc-addr{font-size:.82rem;color:var(--stone-600);margin:0 0 .25rem;line-height:1.45}
.loc-detail{font-size:.78rem;color:var(--stone-500);margin:.5rem 0 0;line-height:1.5}
.loc-link{font-size:.82rem;font-weight:600;margin-top:.625rem;display:inline-block}
@media(max-width:640px){.location-cards{grid-template-columns:1fr}}

.surgery-center-img{width:100%;border-radius:var(--r-xl);margin-bottom:1.5rem;border:1px solid var(--stone-200)}

.hospital-note{margin-top:1.5rem;padding:1.25rem 1.5rem;background:var(--stone-50);border:1px solid var(--stone-200);border-radius:var(--r-lg);font-size:.88rem;color:var(--stone-600);line-height:1.6}
.hospital-note strong{color:var(--stone-900)}

/* ── CTA STRIP ── */
.cta-strip{background:linear-gradient(135deg,var(--navy-900),var(--navy-700));padding:3.5rem 1.5rem;text-align:center;color:#fff}
.cta-strip h2{color:#fff;margin-bottom:.75rem}
.cta-strip p{color:rgba(255,255,255,.7);font-size:1rem;margin-bottom:2rem;max-width:50ch;margin-left:auto;margin-right:auto}
.cta-actions{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap}
.btn{display:inline-flex;align-items:center;justify-content:center;font-weight:600;font-size:.88rem;border-radius:var(--r-md);padding:.75rem 1.75rem;min-height:48px;text-decoration:none;cursor:pointer;border:2px solid transparent;font-family:var(--font)}
.btn-primary{background:var(--blue-600);color:#fff;border-color:var(--blue-600)}
.btn-primary:hover{background:var(--navy-800);border-color:var(--navy-800);color:#fff}
.btn-outline{background:transparent;color:#fff;border-color:rgba(255,255,255,.5)}
.btn-outline:hover{background:rgba(255,255,255,.1);border-color:#fff;color:#fff}

/* ── MOBILE ── */
@media(max-width:640px){
  html{font-size:16px}
  .content-section{padding:2.5rem 1rem}
  .container-narrow{padding:0 1rem}
  .page-hero{padding:2.5rem 1rem 2rem}
  .cta-actions{flex-direction:column;align-items:stretch}
  .content-card{padding:1.5rem}
  .first-visit{padding:1.75rem 1.5rem}
  .author-block{flex-direction:column;text-align:center}
}

