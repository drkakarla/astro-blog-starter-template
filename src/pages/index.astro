.step-marker{display:flex;flex-direction:column;align-items:center}
.step-dot{width:38px;height:38px;border-radius:50%;background:var(--blue-600);color:#fff;font-family:var(--font-display);font-size:.95rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;z-index:1}
