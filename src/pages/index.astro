.first-visit{margin:2.5rem 0;background:linear-gradient(135deg,var(--blue-50) 0%,#fff 100%);border:1px solid var(--blue-200);border-radius:var(--r-2xl);padding:2.25rem;position:relative;overflow:hidden}
