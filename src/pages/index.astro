.step-badge{display:inline-block;font-size:.62rem;font-weight:700;letter-spacing:.05em;text-transform:uppercase;background:var(--blue-100);color:var(--blue-600);padding:.2rem .6rem;border-radius:100px;margin-top:.5rem}

