  .step-dot, .step-dot.preferred { background:#333 !important;box-shadow:none }
  .step-line { background:#ccc }
  .step-badge { background:#eee;color:#333;border:1px solid #ccc }

  /* Avoid page breaks inside key blocks */
  .content-card, .first-visit, .alert-emergency, .patient-quote,
