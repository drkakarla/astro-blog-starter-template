.faq-item summary::-webkit-details-marker{display:none}
.faq-item summary::after{content:'+';font-size:1.25rem;font-weight:300;color:var(--stone-400);flex-shrink:0;transition:transform .2s;width:20px;text-align:center}
.faq-item[open] summary::after{content:'\2212';color:var(--blue-600)}
.faq-answer{padding:0 1.5rem 1.15rem;font-size:.88rem;line-height:1.7;color:var(--stone-600)}
.faq-answer p{margin:0}

